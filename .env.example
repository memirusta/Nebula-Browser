# Google OAuth — Desktop application client (Tauri dev + kurulu surum)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173
GOOGLE_CLIENT_SECRET=

# Kurulu surum: release build sirasinda .env'deki secret binary'ye gomulur (publish-release.ps1).
# Gelistirme icin proje kokundeki .env yeterli.
# AppData override (opsiyonel): %LOCALAPPDATA%\com.nebula.browser\.env

# Updater imza anahtari (build oncesi PowerShell ortam degiskeni; .env dosyasi OKUNMAZ)
# Ilk kurulum: .\scripts\setup-updater-keys.ps1
# Build: $env:TAURI_SIGNING_PRIVATE_KEY = "$env:USERPROFILE\.tauri\nebula.key"
